{
  "name": "website",
  "version": "0.9.11",
  "author": "huangjien@gmail.com",
  "copyright": "Copyright (c) 2025 Jien Huang",
  "description": "A blog website template",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTION='--inspect' next dev -p 8080",
    "build": "next build",
    "test:e2e": "playwright test",
    "start": "next start -p 8080",
    "push": "docker push huangjien/website",
    "make": "docker buildx build --platform linux/amd64 -t huangjien/website .",
    "exe": "docker run --env-file .env.local -ti -d -p 8080:8080 huangjien/website",
    "lint": "next lint",
    "prettier": "prettier --write ."
  },
  "bugs": {
    "url": "https://github.com/huangjien/blog/issues"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "ahooks": "^3.8.4",
    "antd": "^5.25.1",
    "eslint-config-prettier": "^10.1.5",
    "framer-motion": "^12.10.5",
    "http-proxy": "^1.18.1",
    "i18next": "^25.1.2",
    "next": "^15.3.2",
    "next-auth": "^4.24.11",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-toastify": "^11.0.5",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.1.18",
    "tailwind-variants": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3"
  }
}
