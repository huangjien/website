{
  "name": "website",
  "version": "2.0.26",
  "description": "A modern, responsive blog website template built with Next.js, React, and Tailwind CSS",
  "author": {
    "name": "Jien Huang",
    "email": "huangjien@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "keywords": [
    "nextjs",
    "react",
    "blog",
    "website",
    "tailwindcss",
    "typescript",
    "pwa",
    "i18n"
  ],
  "homepage": "https://github.com/huangjien/blog#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/huangjien/blog.git"
  },
  "bugs": {
    "url": "https://github.com/huangjien/blog/issues"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "next dev -p 8080 --webpack",
    "dev:turbo": "next dev -p 8080",
    "check:pages-tests": "node scripts/check-pages-tests.js",
    "prebuild": "pnpm check:pages-tests",
    "build": "next build --webpack",
    "build:webpack": "next build --webpack",
    "start": "next start -p 8080",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit -p jsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "prepare": "husky install",
    "docker:build": "docker buildx build --platform linux/amd64 -t huangjien/website .",
    "docker:push": "docker push huangjien/website",
    "docker:run": "docker run --env-file .env.local -ti -d -p 8080:8080 huangjien/website",
    "clean": "rm -rf .next out node_modules/.cache",
    "analyze": "cross-env ANALYZE=true next build",
    "measure:phase2": "node scripts/measure-phase2-baseline.mjs",
    "measure:phase10": "node scripts/measure-phase10-prodlike.mjs",
    "check:i18n-parity": "node scripts/check-i18n-parity.mjs",
    "perf:ci": "node scripts/check-perf-thresholds.mjs",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert",
    "lhci": "lhci"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/react": "^3.0.210",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@serwist/next": "^9.5.11",
    "@serwist/precaching": "^9.5.11",
    "@serwist/sw": "^9.5.11",
    "@serwist/window": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-virtual": "^3.14.3",
    "ahooks": "^3.9.7",
    "ai": "^6.0.208",
    "clsx": "^2.1.1",
    "eslint-config-prettier": "^10.1.8",
    "framer-motion": "^12.40.0",
    "http-proxy": "^1.18.1",
    "i18next": "^26.3.1",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "openai": "^6.44.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-toastify": "^11.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.4.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.61.1",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.4.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.7",
    "node-mocks-http": "^1.17.2",
    "postcss": "^8.5.15",
    "style-loader": "^4.0.0",
    "tailwindcss": "4.3.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ahooks": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
