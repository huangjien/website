# Test environment variables
# These values are used by Jest during testing
# This file is safe to commit to Git (contains only test values)

# OpenAI API Key (mock value for tests)
OPEN_AI_KEY=test-openai-key
OPENAI_API_KEY=test-openai-key

# GitHub Configuration (test values)
GITHUB_REPO=https://api.github.com/repos/test/test_repo
GITHUB_TOKEN=test-github-token
GITHUB_MEMBER=https://api.github.com/users/test-user

# GitHub OAuth (test values)
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret

# Google OAuth (test values)
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret

# NextAuth Configuration (test values)
NEXTAUTH_SECRET=test-nextauth-secret-for-testing-only
NEXTAUTH_URL=http://localhost:8080
